{
  "name": "@ruthheasman/bsv-micropay-middleware",
  "version": "0.1.0",
  "description": "Express middleware for BSV micropayments. Gate any API endpoint with pay-per-use BSV in one line. Works with BRC-100 wallets, HandCash, Yours, and Metanet. Agent-friendly — no OAuth, no redirects.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "prepare": "npm run build",
    "prepublishOnly": "npm run build",
    "dev:example": "tsx example/server.ts",
    "start": "node dist/example/server.js"
  },
  "keywords": [
    "bsv",
    "bitcoin-sv",
    "micropayments",
    "express",
    "middleware",
    "402",
    "pay-per-use",
    "handcash",
    "brc100",
    "ai-agent",
    "replit"
  ],
  "author": "Ruth Heasman <info@ruthdesigns.co.uk> (https://ruthdesignsdigital.com)",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ruthheasman/bsv-micropay-middleware.git"
  },
  "bugs": {
    "url": "https://github.com/ruthheasman/bsv-micropay-middleware/issues"
  },
  "homepage": "https://github.com/ruthheasman/bsv-micropay-middleware#readme",
  "peerDependencies": {
    "express": "^4.0.0 || ^5.0.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.25",
    "@types/node": "^20.19.37",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  },
  "optionalDependencies": {
    "@bsv/sdk": "^1.10.4"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
